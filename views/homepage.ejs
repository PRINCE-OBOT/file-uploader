<section class="homepage">
  <h2>Drive</h2>
  <h1>Welcome <%= user.firstName %>.</h1>

  <div class="create_folder_and_file_wrap">
    <div class="create_folder act cursor">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        class="create_folder_icon"
        fill="#000"
      >
        <path
          d="M3 6C3 4.9 3.9 4 5 4H9L11 6H19C20.1 6 21 6.9 21 8V18C21 19.1 20.1 20 19 20H5C3.9 20 3 19.1 3 18V6Z"
        />
      </svg>
      Create Folder
    </div>
    <div class="create_file act">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        class="file_icon"
        fill="#000"
      >
        <path
          d="M6 2H14L18 6V20C18 21.1 17.1 22 16 22H6C4.9 22 4 21.1 4 20V4C4 2.9 4.9 2 6 2Z"
        />
        <path d="M14 2V6H18" />
      </svg>
      Create File
      <input type="file" class="createFileInput cursor" multiple />
    </div>
  </div>

  <p class="folder_more_opt_inst">
    Long press on <em>created folder</em> for more options.
  </p>

  <p class="invalid_files_error hide"></p>

  <hr />

  <main>
