<template class="spinner_icon_template">
  <svg
    width="48"
    height="48"
    viewBox="0 0 50 50"
    xmlns="http://www.w3.org/2000/svg"
    class="spinner_icon"
  >
    <circle
      cx="25"
      cy="25"
      r="20"
      fill="none"
      stroke="var(--pri-accent)"
      stroke-width="5"
      stroke-linecap="round"
      stroke-dasharray="90 60"
      class="circle"
    >
      <animateTransform
        attributeName="transform"
        type="rotate"
        from="0 25 25"
        to="360 25 25"
        dur="500ms"
        repeatCount="indefinite"
      />
    </circle>
  </svg>
</template>

<dialog class="file_dialog">
  <form action="" class="file_form">
    <button type="button" class="close_file_dialog act">X</button>

    <div class="invalid_file_inst">
      <p class="invaild_file_inst">File size must not be larger than 1MB</p>
    </div>

    <div class="fileList"></div>
    <button class="uploadBtn act" type="button">Upload</button>
  </form>
</dialog>

<dialog class="modify_folder_dialog">
  <form action="" class="modify_folder_form">
    <button type="button" data-modify-folder-action="new-folder">
      New Folder
    </button>
    <button type="button" class="new_file">
      New File
      <input
        type="file"
        class="createSubFileInput cursor"
        data-modify-folder-action="new-file"
        data-dialog-status="hold"
        multiple
      />
    </button>

    <button type="button" data-modify-folder-action="rename">Rename</button>

    <button
      type="button"
      class="share_link"
      .
      data-modify-folder-action="share-link"
    >
      <div class="expired_at_wrap">
        <label for="expire_at"
          >Expire at
          <input
            type="number"
            placeholder="1"
            id="expire_at"
            class="inp_minutes"
            data-dialog-status="hold"
          />
          minute(s)
        </label>
      </div>
      Share Link
    </button>

    <button
      type="button"
      data-modify-folder-action="delete"
      class="delete_folder"
    >
      Delete
    </button>
  </form>
</dialog>

<script type="module">
  import {
    fetchGet,
    fetchPost,
    getValidUrl,
    getSpinnerIcon,
    removeSpinnerIcon
  } from "/utils/helpers.js";

  const main = document.querySelector("main");

  const fileDialog = document.querySelector(".file_dialog");
  const createFileInput = document.querySelector(".createFileInput");
  const createSubFileInput = document.querySelector(".createSubFileInput");
  const fileList = document.querySelector(".fileList");
  const uploadBtn = document.querySelector(".uploadBtn");
  const closeFileDialog = document.querySelector(".close_file_dialog");
  const modifyFolderDialog = document.querySelector(".modify_folder_dialog");

  const fileDisplayWrap = document.querySelector(".file_display_wrap");
  const fileDisplayWrapContent = document.querySelector(
    ".file_display_wrap_content"
  );
  const invalidFilesError = document.querySelector(".invalid_files_error");
  const fileEmpty = document.querySelector(".file_empty");

  const inpFileName = fileDisplayWrapContent.querySelector(".inp_file_name");
  // file action

  const fileAction = fileDisplayWrapContent.querySelector(
    ".file_display_action_wrap"
  );
  const fileDownload = fileDisplayWrapContent.querySelector(
    ".download_icon_wrap"
  );

  const spinnerIconTemplate = document.querySelector(".spinner_icon_template");

  // file data
  const fileName = fileDisplayWrapContent.querySelector(".file_name");
  const filePreview = fileDisplayWrapContent.querySelector(".file_preview");
  const displayFileSize =
    fileDisplayWrapContent.querySelector(".display_file_size");
  const displayFileMimetype = fileDisplayWrapContent.querySelector(
    ".display_file_mimetype"
  );
  const displayFileCreatedAt = fileDisplayWrapContent.querySelector(
    ".display_file_created_at"
  );
  const displayFileUpdatedAt = fileDisplayWrapContent.querySelector(
    ".display_file_updated_at"
  );

  const openSideBarBtn = document.querySelector(".open_side_bar_btn");
  const closeSideBarBtn = document.querySelector(".close_side_bar_btn");

  const selectedFiles = [];

  const rootFolderAndFileWrap = document.querySelector(
    ".root_folder_and_file_wrap"
  );
  const createFolder = document.querySelector(".create_folder");

  let pressTimer, isTime;

  function createNewFolder(e) {
    const input = rootFolderAndFileWrap.querySelector("input");

    const folderName = input.value.trim();

    if (!folderName) {
      input.remove();
      return;
    }

    rootFolderAndFileWrap.append(getSpinnerIcon(spinnerIconTemplate));

    const params = new URLSearchParams();
    params.append("name", folderName);

    fetchPost(params, renderFoldersAndFiles);
  }

  function handleCreateFolder(e) {
    const isInput = rootFolderAndFileWrap.querySelector("inp_folder_name_root");

    if (isInput) return;

    const inpFolderName = document.createElement("input");
    inpFolderName.id = "inp_folder_name_root";
    inpFolderName.classList.add("inp_folder_name_root");

    inpFolderName.addEventListener("blur", createNewFolder);

    rootFolderAndFileWrap.prepend(inpFolderName);

    inpFolderName.focus();
  }

  function handleCloseFileDialog() {
    fileDialog.close();
    selectedFiles.splice(0);
    createFileInput.value = "";
    fileList.innerHTML = "";
  }

  function handleCreateFile(e) {
    selectedFiles.push(...Array.from(e.target.files));

    if (selectedFiles.length < 1) return;

    fileDialog.showModal();

    renderSelectedFiles();
  }

  function renderSelectedFiles() {
    fileList.innerHTML = "";

    selectedFiles.forEach((file, index) => {
      const fileWrap = document.createElement("div");

      fileWrap.innerHTML = `
          <p>Size: ${(file.size / (1024 * 1024)).toFixed(2)}MB</p>
          <p>Name: ${file.name}</p>
          <label for="rename-file-${index}">Rename:</label><input type="text" id="rename-file-${index}" value="${file.name}" data-index="${index}" />
          <hr/>
        `;

      fileList.appendChild(fileWrap);
    });
  }

  function handleUploadFile() {
    modifyFolderDialog.close();

    const inputs = fileList.querySelectorAll("input");

    const formData = new FormData();

    selectedFiles.forEach((file, index) => {
      const newName = inputs[index].value;

      const renamedFile = new File([file], newName, { type: file.type });

      let folderId = null;

      if (lastClickFolder) {
        const folderWrap = lastClickFolder.closest(".folder_wrap");
        folderId = folderWrap.getAttribute("data-folder-id");
      }

      formData.append("files", renamedFile);
      formData.append("folderId", folderId);
    });

    fileDialog.close();

    rootFolderAndFileWrap.append(
      getSpinnerIcon(spinnerIconTemplate, "uploadFile")
    );

    fetch("/file", {
      method: "POST",
      body: formData
    })
      .then((res) => res.text())
      .then((res) => {
        const obj = JSON.parse(res);

        removeSpinnerIcon(rootFolderAndFileWrap, "uploadFile");

        if (obj.ok) {
          invalidFilesError.classList.add("hide");

          renderFoldersAndFiles();
        } else {
          const invalidFiles = obj.invalidFiles.map(
            (file) =>
              `(file name: ${file.originalname}, size: ${(file.size / (1024 * 1024)).toFixed(2)}MB)`
          );

          invalidFilesError.textContent = `${obj.message}, ${invalidFiles.join(", ")}`;

          invalidFilesError.classList.remove("hide");
        }

        selectedFiles.splice(0);
      })
      .catch((err) => {
        console.log(err);
        console.error("Upload error:", err);
      });
  }

  async function getFiles() {
    const files = await fetchGet("/file");
    appendFiles(files.reverse(), rootFolderAndFileWrap);
  }

  async function getFolders() {
    const folders = await fetchGet("/folder");
    appendFolders(folders.reverse(), rootFolderAndFileWrap);
  }

  function renderFoldersAndFiles() {
    getFolders().then(() => {
      getFiles();
    });
  }

  function appendFiles(files, fileAndFolderWrap) {
    files.forEach((file) => {
      const fileWrap = document.createElement("div");
      const fileName = document.createElement("div");

      fileWrap.classList.add("file_wrap");
      fileName.classList.add("file_name", "cursor");

      fileName.textContent = file.name;

      fileWrap.setAttribute("data-file-id", `${file.id}`);

      fileWrap.append(fileName);
      fileAndFolderWrap.append(fileWrap);
    });
  }

  function appendFolders(folders, fileAndFolderWrap) {
    fileAndFolderWrap.innerHTML = "";

    folders.forEach((folder) => {
      const folderWrap = document.createElement("details");
      const folderNameWrap = document.createElement("summary");
      const folderName = document.createElement("span");
      const inpFolderName = document.createElement("input");
      const subFolderAndFileWrap = document.createElement("div");

      folderWrap.classList.add("folder_wrap");
      folderNameWrap.classList.add("folder_name_wrap");
      folderName.classList.add("folder_name", "cursor");
      subFolderAndFileWrap.classList.add("sub_folder_and_file_wrap");
      inpFolderName.classList.add("inp_folder_name", "hide");

      folderName.textContent = folder.name;

      folderWrap.setAttribute("data-folder-id", `${folder.id}`);
      folderNameWrap.append(folderName, inpFolderName);
      folderWrap.append(folderNameWrap, subFolderAndFileWrap);

      fileAndFolderWrap.append(folderWrap);
    });
  }

  function displayFile(subFiles, subFolderAndFileWrap) {
    appendFiles(subFiles, subFolderAndFileWrap);
  }

  async function displaySubFoldersAndFiles(e, folderWrap) {
    rootFolderAndFileWrap.append(getSpinnerIcon(spinnerIconTemplate));

    const folderId = folderWrap.getAttribute("data-folder-id");
    const subFolderAndFileWrap = folderWrap.querySelector(
      ".sub_folder_and_file_wrap"
    );

    const folder = await fetchGet(`/folder/${folderId}`);

    const subFolders = folder.children || [];
    const subFiles = folder.files || [];

    subFolderAndFileWrap.innerHTML = "";

    appendFolders(subFolders, subFolderAndFileWrap);
    displayFile(subFiles, subFolderAndFileWrap);

    removeSpinnerIcon(rootFolderAndFileWrap);
  }

  async function displayFileData(fileWrap) {
    fileDisplayWrapContent.append(
      getSpinnerIcon(spinnerIconTemplate, "fileData")
    );

    const fileId = fileWrap.getAttribute("data-file-id");

    const file = await fetchGet(`/file/${fileId}`);

    fileDownload.href = `file/${file.id}/download`;

    fileDisplayWrapContent.classList.remove("hide");
    fileEmpty.classList.add("hide");
    inpFileName.classList.add("hide");
    fileName.classList.remove("hide");

    fileDisplayWrapContent.setAttribute("data-file-id", `${file.id}`);
    filePreview.src = getValidUrl(file.url);
    filePreview.alt = file.name;
    fileName.textContent = file.name;
    displayFileSize.textContent = `${(file.size / 1024).toFixed(2)}KB`;
    displayFileMimetype.textContent = file.mimetype;
    displayFileCreatedAt.textContent = file.createdAt;
    displayFileUpdatedAt.textContent = file.updatedAt;

    removeSpinnerIcon(fileDisplayWrapContent, "fileData");
  }

  function handleFolderAndFileOpen(e) {
    const folderWrap = e.target.closest("[data-folder-id]");

    if (folderWrap && !folderWrap.open) {
      displaySubFoldersAndFiles(e, folderWrap);
    } else {
      const fileWrap = e.target.closest("[data-file-id]");

      if (fileWrap) {
        displayFileData(fileWrap);
      }
    }
  }

  let lastClickFolder;

  const getLastClickFolderId = () => {
    const folderWrap = lastClickFolder.closest(".folder_wrap");

    const folderId = folderWrap.getAttribute("data-folder-id");

    return folderId;
  };

  const modifyFolderAction = {
    "new-folder": () => {
      modifyFolderDialog.close();

      const folderWrap = lastClickFolder.closest(".folder_wrap");

      const immediateSubFolder = folderWrap.querySelector(
        ".folder_name_wrap + .sub_folder_and_file_wrap"
      );

      const inpSubFolderName = document.createElement("input");

      folderWrap.open = true;

      immediateSubFolder.prepend(inpSubFolderName);

      const folderId = folderWrap.getAttribute("data-folder-id");

      inpSubFolderName.addEventListener("blur", () => {
        createSubFolder(folderId, inpSubFolderName);
      });

      inpSubFolderName.focus();
    },

    rename: () => {
      modifyFolderDialog.close();

      const folderWrap = lastClickFolder.closest(".folder_wrap");
      const inpFolderName = folderWrap.querySelector(".inp_folder_name");
      const folderName = folderWrap.querySelector(".folder_name");

      inpFolderName.value = folderName.textContent;

      inpFolderName.classList.remove("hide");
      folderName.classList.add("hide");

      inpFolderName.focus();

      inpFolderName.addEventListener("blur", () => {
        const folderId = folderWrap.getAttribute("data-folder-id");

        const trimInpFolderName = inpFolderName.value.trim();

        if (!trimInpFolderName) {
          inpFolderName.classList.add("hide");
          folderName.classList.remove("hide");
        } else {
          const params = new URLSearchParams();
          params.append("name", trimInpFolderName);

          fetch(`/folder/${folderId}`, {
            method: "PUT",
            body: params
          })
            .then((res) => res.text())
            .then((res) => {
              if (!JSON.parse(res).ok) return;
              folderName.textContent = inpFolderName.value;

              inpFolderName.classList.add("hide");
              folderName.classList.remove("hide");
              renderFoldersAndFiles();
            })
            .catch((err) => {
              console.error("Upload error:", err);
            });
        }
      });
    },

    "share-link": async () => {
      const params = new URLSearchParams();

      const expiresAt =
        parseInt(document.querySelector(".inp_minutes").value) || 1;

      params.append("folderId", getLastClickFolderId());
      params.append("minutes", expiresAt);

      fetchPost(
        params,
        () => {
          try {
            navigator.clipboard.writeText(
              `${location.host}/share/${getLastClickFolderId()}`
            );
          } catch (err) {
            console.error("Failed to copy", err);
          }
        },
        "/share"
      );
    },
    delete: () => {
      const folderId = getLastClickFolderId();

      fetch(`/folder/${folderId}`, {
        method: "DELETE"
      })
        .then((res) => res.text())
        .then((res) => {
          if (!JSON.parse(res).ok) return;

          console.log("Folder Deleted Successfully");
          renderFoldersAndFiles();
        })
        .catch((err) => {
          console.error("Folder deletion error:", err);
        });
    }
  };

  function createSubFolder(parentId, input) {
    const folderName = input.value.trim();

    if (!folderName) {
      input.remove();
      return;
    }

    rootFolderAndFileWrap.append(getSpinnerIcon(spinnerIconTemplate));

    const params = new URLSearchParams();

    params.append("parentId", parentId);
    params.append("name", folderName);

    fetchPost(params, renderFoldersAndFiles);
  }

  function handleModifyFolderAction(e) {
    const action = e.target.dataset.modifyFolderAction;

    if (!action || !lastClickFolder) return;

    if (typeof action !== "function") return;

    modifyFolderAction[action]();
  }

  function handleShowModifyFolderDialog(e) {
    if (!e.target.classList.contains("folder_name")) return;

    pressTimer = setTimeout(() => {
      lastClickFolder = e.target;

      modifyFolderDialog.showModal();

      isTime = true;
    }, 500);
  }

  function cancelPress() {
    clearTimeout(pressTimer);
  }

  function handleRenameFileName() {
    fileDisplayWrapContent.append(
      getSpinnerIcon(spinnerIconTemplate, "renameFile")
    );

    const fileId = fileDisplayWrapContent.getAttribute("data-file-id");

    const newName = inpFileName.value;

    fileName.classList.remove("hide");
    inpFileName.classList.add("hide");

    const params = new URLSearchParams();
    params.append("name", newName);

    fetch(`/file/${fileId}`, {
      method: "PUT",
      body: params
    })
      .then((res) => res.text())
      .then((res) => {
        removeSpinnerIcon(fileDisplayWrapContent, "renameFile");

        if (!JSON.parse(res).ok) return;
        fileName.textContent = newName;

        renderFoldersAndFiles();
      })
      .catch((err) => {
        console.error("Upload error:", err);
      });
  }

  const fileActionObj = {
    rename: () => {
      const input = fileDisplayWrapContent.querySelector(".inp_file_name");
      const name = fileDisplayWrapContent.querySelector(".file_name");

      input.value = name.textContent;

      name.classList.add("hide");
      input.classList.remove("hide");

      input.focus();
    },

    delete: () => {
      fileDisplayWrapContent.append(
        getSpinnerIcon(spinnerIconTemplate, "deleteFile")
      );

      const fileId = fileDisplayWrapContent.getAttribute("data-file-id");

      fetch(`/file/${fileId}`, {
        method: "DELETE"
      })
        .then((res) => res.text())
        .then((res) => {
          removeSpinnerIcon(fileDisplayWrapContent, "deleteFile");

          if (!JSON.parse(res).ok) return;

          fileDisplayWrapContent.classList.add("hide");

          fileEmpty.classList.remove("hide");

          console.log("File Deleted Successfully");

          renderFoldersAndFiles();
        })
        .catch((err) => {
          console.error("Upload error:", err);
        });
    }
  };

  function handleFileAction(e) {
    const action = e.target.dataset.fileAction;

    if (!action) return;

    fileActionObj[action]();
  }

  function closeDialogModal(e) {
    const isSelectNewFile = e.target;
    if (e.target.dataset.dialogStatus === "hold") return;

    if (!isTime && modifyFolderDialog.open) {
      modifyFolderDialog.close();
    }

    isTime = false;
  }

  function navLeftSideBar(method) {
    rootFolderAndFileWrap.classList[method]("show");
    fileDisplayWrap.classList[method]("blur");
    closeSideBarBtn.classList[method === "add" ? "remove" : "add"]("hide");
  }

  renderFoldersAndFiles();

  uploadBtn.addEventListener("click", handleUploadFile);

  createFileInput.addEventListener("change", (e) => {
    lastClickFolder = null;
    handleCreateFile(e);
  });

  createSubFileInput.addEventListener("change", handleCreateFile);

  closeFileDialog.addEventListener("click", handleCloseFileDialog);

  createFolder.addEventListener("click", handleCreateFolder);

  rootFolderAndFileWrap.addEventListener("click", handleFolderAndFileOpen);

  rootFolderAndFileWrap.addEventListener(
    "pointerdown",
    handleShowModifyFolderDialog
  );
  rootFolderAndFileWrap.addEventListener("pointerleave", cancelPress);
  rootFolderAndFileWrap.addEventListener("pointerup", cancelPress);
  rootFolderAndFileWrap.addEventListener("pointercancel", cancelPress);

  modifyFolderDialog.addEventListener("click", handleModifyFolderAction);
  // file action

  fileAction.addEventListener("click", handleFileAction);
  inpFileName.addEventListener("blur", handleRenameFileName);

  document.body.addEventListener("click", closeDialogModal);

  openSideBarBtn.addEventListener("click", () => {
    navLeftSideBar("add");
  });

  closeSideBarBtn.addEventListener("click", () => {
    navLeftSideBar("remove");
  });
</script>
